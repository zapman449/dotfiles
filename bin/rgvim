#!/bin/bash

set -euo pipefail

function USAGE {
    echo "rgvim <search regexp> [subdirectory] [subdir2...]"
    exit 1
}

search=""

if [[ -z ${1:-} ]] ; then
    USAGE
elif [[ -n ${2:-} ]]; then
    search=${1}
    shift
    rg --files-with-matches -0 "${search}" -g '!vendor/' "$@" | xargs -0 -o vim
else
    search=${1}
    rg --files-with-matches -0 "${search}" -g '!vendor/' . | xargs -0 -o vim
fi
